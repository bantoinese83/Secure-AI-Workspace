    "@base-ui/react": "^1.2.0",
    "@tavily/core": "^0.7.2",
    "aws-amplify": "^6.16.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
